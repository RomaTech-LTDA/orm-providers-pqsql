{
  "name": "@romatech/orm-providers-pgsql",
  "version": "1.0.0",
  "description": "PostgreSQL provider for RomaTech ORM",
  "author": "RomaTech/Leandro Romanelli",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/romatech-ltda/orm-providers-pgsql"
  },
  "homepage": "https://github.com/romatech-ltda/orm-providers-pgsql#readme",
  "bugs": {
    "url": "https://github.com/romatech-ltda/orm-providers-pgsql/issues"
  },
  "keywords": [
    "orm",
    "postgresql",
    "postgres",
    "pg",
    "romatech",
    "database",
    "typescript"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "pg": "^8.11.0"
  },
  "peerDependencies": {
    "@romatech/orm": "^1.0.0"
  },
  "devDependencies": {
    "@romatech/orm": "file:../romatech-orm",
    "@types/node": "^24.1.0",
    "@types/pg": "^8.11.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
